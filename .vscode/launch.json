{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Attach to Docker Container",
            "type": "coreclr",
            "request": "attach",
            "processId": "${command:pickRemoteProcess}",
            "pipeTransport": {
                "pipeProgram": "docker",
                "pipeArgs": [
                    "exec",
                    "-i",
                    "${command:docker.pickContainer}"
                ],
                "debuggerPath": "/vsdbg/vsdbg",
                "pipeCwd": "${workspaceFolder}",
                "quoteArgs": false
            },
            "sourceFileMap": {
                // IMPORTANT: Change "/app" to match the WORKDIR in your Dockerfile
                "/app": "${workspaceFolder}"
            }
        }
    ]
}